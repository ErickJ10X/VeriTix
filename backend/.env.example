# APP
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# DATABASE (local, without Docker)
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/<dbname>?schema=public"

# DATABASE (Docker Compose)
POSTGRES_DB=veritix_db
POSTGRES_USER=veritix_user
POSTGRES_PASSWORD=change_me

# AUTH
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars!!
JWT_EXPIRATION=24h
JWT_ISSUER=veritix-api

# ENCRYPTION QR
AES_SECRET_KEY=your_32_char_aes_key_here_exactly!

# EMAIL
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=tickets@veritix.app

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379

# RATE LIMITING
THROTTLE_TTL=60000
THROTTLE_LIMIT=100